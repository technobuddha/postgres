  "scripts": {
    "start": "build dev",
    "build": "build default",
    "publish": "build publish",
    "test": "npx vitest --typecheck run",
    "test:watch": "npx vitest --typecheck --no-coverage watch",
    "test:full": "npx vitest --typecheck --mode=full run",
    "lint": "npx eslint src",
